{
  "name": "bytewise-ios-dependencies",
  "version": "1.2.0",
  "description": "iOS-specific dependencies for ByteWise Nutritionist",
  "dependencies": {
    "@capacitor/cli": "^5.6.0",
    "@capacitor/core": "^5.6.0",
    "@capacitor/ios": "^5.6.0",
    "@capacitor/status-bar": "^5.0.6",
    "@capacitor/splash-screen": "^5.0.6",
    "@capacitor/haptics": "^5.0.6",
    "@capacitor/local-notifications": "^5.0.6",
    "@capacitor/push-notifications": "^5.1.0",
    "@capacitor/camera": "^5.0.7",
    "@capacitor/filesystem": "^5.1.4",
    "@capacitor/device": "^5.0.6",
    "@capacitor/network": "^5.0.6",
    "@capacitor/storage": "^1.2.5",
    "@capacitor/keyboard": "^5.0.6",
    "@capacitor/app": "^5.0.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  },
  "scripts": {
    "ios:install": "npm install",
    "ios:init": "npx cap init 'ByteWise Nutritionist' 'com.bytewise.nutritionist'",
    "ios:add": "npx cap add ios",
    "ios:sync": "npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:build": "npm run build && npx cap sync ios",
    "ios:run": "npx cap run ios",
    "ios:clean": "npx cap clean ios"
  }
}