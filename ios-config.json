{
  "app_name": "ByteWise Nutritionist",
  "bundle_id": "com.bytewise.nutritionist",
  "version": "1.0.0",
  "build_number": "1",
  "display_name": "ByteWise",
  "description": "Professional nutrition tracking with USDA database integration",
  "category": "Health & Fitness",
  "required_device_capabilities": ["arm64"],
  "supported_interface_orientations": [
    "UIInterfaceOrientationPortrait",
    "UIInterfaceOrientationPortraitUpsideDown"
  ],
  "app_icons": {
    "required_sizes": [
      "20x20", "29x29", "40x40", "58x58", "60x60",
      "76x76", "80x80", "87x87", "120x120", "152x152",
      "167x167", "180x180", "1024x1024"
    ],
    "source_directory": "public/icons/",
    "target_directory": "ios/App/App/Assets.xcassets/AppIcon.appiconset/"
  },
  "launch_screen": {
    "background_color": "#ffffff",
    "image_name": "ByteWise-Launch",
    "content_mode": "scaleAspectFit"
  },
  "info_plist_additions": {
    "CFBundleDisplayName": "ByteWise",
    "CFBundleShortVersionString": "1.0.0",
    "CFBundleVersion": "1",
    "LSRequiresIPhoneOS": true,
    "UILaunchStoryboardName": "LaunchScreen",
    "UIRequiredDeviceCapabilities": ["arm64"],
    "UISupportedInterfaceOrientations": [
      "UIInterfaceOrientationPortrait",
      "UIInterfaceOrientationPortraitUpsideDown"
    ],
    "NSCameraUsageDescription": "ByteWise uses the camera to scan food barcodes and capture meal photos for nutrition tracking.",
    "NSPhotoLibraryUsageDescription": "ByteWise accesses photos to let you add meal images to your nutrition log.",
    "NSLocationWhenInUseUsageDescription": "ByteWise can use location to find nearby restaurants and grocery stores for meal planning."
  },
  "deployment_target": "13.0",
  "swift_version": "5.0"
}