{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build && cp -r dist/public server/",
    "watchPatterns": [
      "server/**",
      "client/**",
      "shared/**"
    ]
  },
  "deploy": {
    "startCommand": "npm start",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "numReplicas": 1,
    "region": "us-west1"
  },
  "environments": {
    "production": {
      "build": {
        "buildCommand": "npm run build && cp -r dist/public server/"
      },
      "deploy": {
        "startCommand": "npm start"
      }
    }
  }
}