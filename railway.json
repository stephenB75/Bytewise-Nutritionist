{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "vite build && esbuild server/prod-index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "watchPatterns": [
      "server/**",
      "client/**",
      "shared/**"
    ]
  },
  "deploy": {
    "startCommand": "NODE_ENV=production node dist/prod-index.js",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "numReplicas": 1,
    "region": "us-west1"
  },
  "environments": {
    "production": {
      "build": {
        "buildCommand": "vite build && esbuild server/prod-index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist"
      },
      "deploy": {
        "startCommand": "NODE_ENV=production node dist/prod-index.js"
      }
    }
  }
}