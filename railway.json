{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build",
    "watchPatterns": [
      "server/**",
      "client/**",
      "shared/**"
    ]
  },
  "deploy": {
    "startCommand": "npm run start",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "numReplicas": 1,
    "region": "us-west1"
  },
  "environments": {
    "production": {
      "build": {
        "buildCommand": "npm run build"
      },
      "deploy": {
        "startCommand": "npm run start"
      }
    }
  }
}